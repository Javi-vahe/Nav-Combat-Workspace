<launch>

  <node pkg="jie_ware" type="lidar_loc" name="lidar_loc" output="screen">
    <param name="base_frame" value="base_link" />
    <param name="odom_frame" value="odom" />
    <param name="laser_frame" value="laser" />
    <param name="laser_topic" value="scan" />
    <param name="freq" value="20" />
    <param name="use_kf" value="true" />
    <param name="pub_kf_result" value="true" />

    <!-- 噪声参数 -->
    <param name="Q_x" value="1.0"/>
    <param name="R_x" value="3.0"/>
    <param name="Q_y" value="1.0"/>
    <param name="R_y" value="3.0"/>
    <param name="Q_yaw" value="1,0"/>
    <param name="R_yaw" value="4.0"/>
  </node>

</launch>
