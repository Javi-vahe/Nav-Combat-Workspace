<launch>
  <node name="rplidarNode"          pkg="rplidar_ros"  type="rplidarNode" output="screen">
    <param name="channel_type"        type="string" value="udp"/>  
    <param name="udp_ip"              type="string" value="192.168.11.2"/>  
    <param name="frame_id"            type="string" value="laser"/>
    <param name="inverted"            type="bool"   value="false"/>
    <param name="angle_compensate"    type="bool"   value="true"/>
    <param name="angle_min"           type="double" value="0.0"/>
    <param name="angle_max"           type="double" value="360.0"/>
    <param name="angle_skip"          type="bool"   value="true"/>
    <param name="angle_skip_start"    type="double" value="137.0"/>
    <param name="angle_skip_end"      type="double" value="225.0"/>
    <param name="scan_mode"           type="string" value="UltraDense"/>
    <param name="scan_frequency"      type="int"    value="15"/>
  </node>
</launch>
