<root BTCPP_format="3"
      main_tree_to_execute="mainTree">
  <BehaviorTree ID="mainTree">
    <Sequence>
      <CompareBiggerInt a="{correct_material}"
                        b="2"
                        cout=""/>
    </Sequence>
